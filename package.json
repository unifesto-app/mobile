{
  "name": "unifesto-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:expo-go": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "reset": "expo start --clear",
    "reset:hard": "watchman watch-del-all && rm -rf node_modules/.cache && rm -rf .expo && expo start --dev-client --clear"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
